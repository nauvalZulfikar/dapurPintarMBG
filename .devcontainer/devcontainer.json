{
  "name": "DPMBG Kitchen",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "updateContentCommand": "pip3 install --user -r requirements.txt && cd frontend && npm install && npm run build && echo '✅ Ready'",
  "postAttachCommand": {
    "server": "uvicorn backend.app:app --host 0.0.0.0 --port 8000 --reload"
  },
  "portsAttributes": {
    "8000": {
      "label": "Application",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    8000
  ]
}
