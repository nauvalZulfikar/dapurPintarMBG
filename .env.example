# Database (leave empty to use local SQLite at backend/local_scans.db)
DATABASE_URL=postgresql://...

# JWT (generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=change_me_to_a_random_32_plus_char_string

# Timezone (used for local scan timestamps)
TZ_REGION=Asia/Jakarta

# Public URL the countdown QR codes point to
API_BASE_URL=https://dapurpintarmbg.aureonforge.com

# Optional: allowed CORS origins (comma-separated) for dev
# ALLOWED_ORIGINS=http://localhost:5173

# Cloud print agent (only if using a separate Windows printer poller — leave commented for local print)
# PRINTER_AGENT_URL=http://printer-agent.local:9100
# PRINTER_TYPE=cloud   # cloud | local

# ── Legacy single-kitchen fallbacks (optional in multi-kitchen mode) ────────
# These are only used to seed kitchen id=1 during initial migration.
# After migration, each kitchen has its own scanner_key / cloud_print_key /
# printer_name in the `kitchens` table and these env vars become unused.

# PRINTER_NAME=DPMBGPasehZP550
# PRINTER_LANG=ZPL
# LABEL_TITLE=MBG Kitchen
# SCANNER_KEY=legacy_scanner_key_from_kitchen_1
# CLOUD_PRINT_KEY=legacy_cloud_print_key_from_kitchen_1

# Local direct print mode — set to true when backend runs on the same box as the printer
# LOCAL_PRINT=false

# ── Feature flags per phase (Phase 0+) ──────────────────────────────────────
# Each phase ships behind a flag. Default `false`; flip to `true` after the
# phase's acceptance checks pass in production. No redeploy needed if the
# backend reloads env (or set them at container-create time).

# FEATURE_PHASE_1_SCHOOL_MIGRATE=false      # schools JSON → DB + supplier master
# FEATURE_PHASE_2_MENU_APPROVAL=false       # reverse optimizer + approval workflow
# FEATURE_PHASE_3_JOINT_INSPECTION=false    # 3-sign-off + PO checklist + container split
# FEATURE_PHASE_4_PRODUCTION_BATCH=false    # batch + auto-debit + tablet head_chef Processing scan
# FEATURE_PHASE_5_DISTRIBUTION=false        # wave classifier + receipt confirm
# FEATURE_PHASE_6_AKUNTAN=false             # PO + expense + LRA biweekly
# FEATURE_PHASE_7_ASLAP=false               # daily checklist + water quality
# FEATURE_PHASE_8_NOTIFICATIONS=false       # in-app + push PWA
# FEATURE_PHASE_9_EXECUTIVE=false           # multi-level dashboards + compliance bundle
